# DROP beta waitlist — environment variables
# Set these as DROP per-app secrets (Settings → Secrets) or export them locally.
#
# Day-to-day config — email provider (None/Resend/SMTP), the SMTP mailbox,
# the from name/address, and the invites toggle — lives in the admin UI →
# Settings and is stored in waitlist.json. Most vars below are only the
# fallback/seed used until a value is saved there. WAITLIST_ADMIN_TOKEN,
# DROP_ADMIN_API_KEY, and RESEND_API_KEY are hard secrets: env-only, never
# readable or writable through Settings.

# ── Required ──────────────────────────────────────────────────────────────────

# Token for the /admin UI and /api/admin/* endpoints. Env-only.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WAITLIST_ADMIN_TOKEN=

# ── Invites (account creation) ────────────────────────────────────────────────

# A DROP admin API key used to create beta accounts. Env-only — never exposed
# through Settings. Leave unset while collecting signups; set before enabling invites.
DROP_ADMIN_API_KEY=

# Seed/fallback only, default off — the invites toggle itself is saved in the
# admin UI (Settings) once flipped there; until then this env value applies.
# Set to true ONLY after Docker isolation is running on the server
# (DROP_ISOLATION=docker), because approved users can deploy code.
WAITLIST_INVITES_ENABLED=false

# ── Email ─────────────────────────────────────────────────────────────────────
#
# The email provider (None / Resend / SMTP), from name/address, and — for
# SMTP — host/port/username/password are all configured in the admin UI →
# Settings and stored in waitlist.json. There are NO SMTP_* env vars; SMTP
# credentials live only in the data file (0600 permissions on Linux). Use the
# Settings page's test-email button to confirm delivery.

# Resend API key. Env-only. Set it, then pick "Resend" as the provider in
# Settings. Without it, the Resend provider can't be used (SMTP is unaffected).
RESEND_API_KEY=

# Seed/fallback "from" address used until a from is saved in Settings.
# Verify the domain in Resend for deliverability.
EMAIL_FROM=DROP <noreply@example.com>

# ── Optional overrides ────────────────────────────────────────────────────────

# DROP API base URL (default: http://127.0.0.1:3000). Use the host gateway
# when running under Docker network isolation.
# DROP_API_URL=http://127.0.0.1:3000

# Base URL for the dashboard link in the welcome email (defaults to DROP_API_URL).
# DASHBOARD_URL=https://app.example.com

# ── Rate limiting & abuse protection ─────────────────────────────────────────

# Max join requests per IP per window (default: 20).
# WAITLIST_JOIN_LIMIT=20

# Window duration in ms (default: 3600000 = 1 hour).
# WAITLIST_JOIN_WINDOW_MS=3600000

# Max confirmation + test emails sent across ALL clients per hour (default: 200).
# Protects the configured provider from relay abuse under a distributed flood;
# signups still stored when exceeded. Does not apply to admin-triggered invite
# emails. The test-email endpoint also has its own 5/min per-IP limit on top.
# WAITLIST_EMAIL_BUDGET_PER_HOUR=200

# Comma-separated list of extra trusted proxy IPs beyond loopback/RFC-1918.
# Only needed if your Caddy or load-balancer runs on a non-private address.
# TRUSTED_PROXY_IPS=

# Injected automatically by DROP — no need to set these manually.
# PORT=3000
# DROP_DATA_DIR=/var/drop/data/apps/<app-name>
